# =============================================================
# FLOWSTATE -- Environment Variables
# Copy this to .env and fill in your values.
# .env is git-ignored and should NEVER be committed.
# Set these as Windows Machine env vars (see docs/credentials-setup.md).
# =============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Imgur (free image/video hosting so Instagram/Threads can pull media) ---
IMGUR_CLIENT_ID=your_imgur_client_id

# --- Instagram Graph API (free) ---
INSTAGRAM_USER_ID=your_ig_user_id
INSTAGRAM_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
# Token expires every 60 days. Refresh command:
# https://graph.facebook.com/v18.0/oauth/access_token?grant_type=fb_exchange_token&client_id=APP_ID&client_secret=APP_SECRET&fb_exchange_token=CURRENT_TOKEN

# --- Threads API (free) ---
THREADS_USER_ID=your_threads_user_id
THREADS_ACCESS_TOKEN=THBxxxxxxxxxxxxxxxx
# Refresh command:
# https://graph.threads.net/access_token?grant_type=th_exchange_token&client_id=APP_ID&client_secret=APP_SECRET&access_token=CURRENT_TOKEN

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+1XXXXXXXXXX

# --- ngrok public URL (update each time ngrok restarts unless you have a static domain) ---
N8N_WEBHOOK_URL=https://xxxx.ngrok-free.app

# --- Content paths ---
CONTENT_BASE=D:\your-content-folder
APPROVED_BASE=D:\your-content-folder_approved
VAULT_BASE=D:\your-content-folder_vault
SCRIPTS_DIR=D:\your-content-folder\scripts
