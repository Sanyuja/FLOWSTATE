# ============================================================
# FLOWSTATE .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.
# ============================================================

# ── AI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── APPROVAL INTERFACE (WhatsApp via Twilio) ─────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+1YOURNUMBER

# ── IMAGE HOSTING (so platforms can pull your media) ─────────
IMGUR_CLIENT_ID=...

# ── SOCIAL PLATFORMS (add only what you use) ─────────────────

# Instagram
INSTAGRAM_USER_ID=...
INSTAGRAM_ACCESS_TOKEN=...
# Note: Instagram tokens expire every 60 days. Set a reminder at day 50.

# Threads
THREADS_USER_ID=...
THREADS_ACCESS_TOKEN=...

# LinkedIn
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...
LINKEDIN_ACCESS_TOKEN=...

# Medium
MEDIUM_INTEGRATION_TOKEN=...

# ── WEBHOOK TUNNEL (for local n8n to receive WhatsApp replies) ─
# ngrok creates this automatically — no key needed on free tier
# Your ngrok URL changes on restart unless you use a paid static domain
NGROK_URL=https://your-ngrok-url.ngrok.io

# ── OPTIONAL: Trend intelligence ─────────────────────────────
# PERPLEXITY_API_KEY=pplx-...
