# =============================================================
# FLOWSTATE .gitignore
# Share the framework. Keep your personal config private.
# =============================================================

# --- Secrets & credentials ---
.env
.env.*
!.env.example
*.key
*.pem

# --- Your personal persona config (edit the example, don't commit yours) ---
config/persona.json
config/personas/

# --- Runtime state files (generated, not source) ---
pending_approvals.json
pending_approvals_*.json
pending_reels.json
*_temp.json
*_args_temp.json

# --- Content & media (never commit) ---
*.jpg
*.jpeg
*.png
*.gif
*.mp4
# Exception: repo assets (demo GIFs, screenshots)
!assets/
!assets/*.gif
!assets/*.png
!assets/*.jpg
*.mov
*.avi
*.webm
*.mp3
*.wav
*.csv
*.xlsx

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
venv/
.venv/
env/

# --- Node ---
node_modules/
npm-debug.log*
package-lock.json

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~

# --- IDE ---
.vscode/
.idea/
*.code-workspace
